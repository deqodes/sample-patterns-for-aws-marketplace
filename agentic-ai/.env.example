# Module 5 — Environment Variables
# Copy this file to .env and fill in your values before running demos.
# Never commit .env to version control.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Mock Mode ─────────────────────────────────────────────────────────────────
# Set to true to use mock tool data (no partner API keys needed).
# LLM calls via Bedrock are always live regardless of this setting.
AGENT_MOCK_DOMAIN=true

# ── Algolia (Customer Domain) ─────────────────────────────────────────────────
# Sign up free at algolia.com — use the Search API key (not Admin/Write)
ALGOLIA_APP_ID=<your-algolia-app-id>
ALGOLIA_API_KEY=<your-algolia-search-api-key>

# ── Deepgram (Voice Domain) ───────────────────────────────────────────────────
# Sign up free at console.deepgram.com — $200 free credit, no card required
DEEPGRAM_API_KEY=<your-deepgram-api-key>

# ── Mapbox (Geospatial Domain) ────────────────────────────────────────────────
# Sign up free at account.mapbox.com — default public token works for dev
MAPBOX_ACCESS_TOKEN=<your-mapbox-access-token>

# ── Amazon Location Service (Geospatial Domain) ───────────────────────────────
# Create these resources in your AWS account (us-east-1 recommended):
#   aws location create-place-index --index-name devops-place-index --data-source Esri --pricing-plan RequestBasedUsage --region us-east-1
#   aws location create-route-calculator --calculator-name devops-route-calculator --data-source Esri --pricing-plan RequestBasedUsage --region us-east-1
AGENT_LOCATION_INDEX_NAME=devops-place-index
AGENT_LOCATION_ROUTE_CALCULATOR=devops-route-calculator

# ── Amazon Lex V2 (Customer Domain — optional, mock handles it by default) ────
# AGENT_LEX_BOT_ID=<your-lex-bot-id>

# ── Amazon Personalize (Customer Domain — optional, mock handles it by default)
# AGENT_PERSONALIZE_CAMPAIGN_ARN=<your-campaign-arn>

# ── Amazon Connect (Customer Domain — optional, mock handles it by default) ───
# AGENT_CONNECT_INSTANCE_ID=<your-connect-instance-id>
# AGENT_CONNECT_CONTACT_FLOW_ID=<your-contact-flow-id>
